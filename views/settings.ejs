<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>DS FX Book | <%= title %></title><link rel="stylesheet" href="/style.css" /></head>
<body><div class="app-shell"><%- include("partials/sidebar") %><main class="main-area"><%- include("partials/topbar", { title }) %><div class="grid-two"><article class="panel"><h3>Account Access</h3><form id="register-form" class="form-grid"><input type="text" id="register-name" placeholder="Name" required /><input type="email" id="register-email" placeholder="Email" required /><input type="password" id="register-password" placeholder="Password" required /><button type="submit" class="btn">Create Account</button></form><form id="login-form" class="form-grid"><input type="email" id="login-email" placeholder="Email" required /><input type="password" id="login-password" placeholder="Password" required /><button type="submit" class="btn">Login</button></form><div class="button-row"><p id="auth-status" class="muted">Not logged in.</p><button id="logout-btn" class="btn alt" type="button">Logout</button></div></article><article class="panel"><h3>MT4/MT5 Connection</h3><form id="sync-form" class="form-grid"><input type="text" id="sync-broker" placeholder="Broker" required /><select id="sync-platform"><option value="MT4">MT4</option><option value="MT5">MT5</option></select><input type="text" id="sync-account" placeholder="Account Number" required /><button type="submit" class="btn">Connect</button></form><p id="sync-status" class="muted">No account connected.</p><button id="refresh-mt5-events" class="btn alt" type="button">Refresh MT5 Events</button><ul id="mt5-events" class="entry-list"></ul></article></div></main></div><script src="/script.js"></script></body>
</html>
